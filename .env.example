# Copy this file to `.env` in the project root and fill in your local MySQL password.
# See README.md for database setup and running the app.

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=scheduforge

# API server port (Vite proxies /api to this port)
PORT=3001

# --- Docker Compose only (optional): set MYSQL_ROOT_PASSWORD to match the DB container ---
# MYSQL_ROOT_PASSWORD=your_mysql_password_here
